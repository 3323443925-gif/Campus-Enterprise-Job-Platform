<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.MajorMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.pojo.Major">
        <id column="id" property="id"/>
        <result column="major_name" property="majorName"/>
        <result column="major_code" property="majorCode"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, major_name, major_code, remark, create_time, update_time, is_deleted
    </sql>

    <!-- 查询所有专业 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM major
        WHERE is_deleted = 0
        ORDER BY id ASC
    </select>

    <!-- 根据ID查询专业 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM major
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            AND is_deleted = 0
        </where>
    </select>

    <!-- 根据专业编码查询专业 -->
    <select id="findByMajorCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM major
        <where>
            <if test="majorCode != null and majorCode != ''">
                AND major_code = #{majorCode}
            </if>
            AND is_deleted = 0
        </where>
    </select>

    <!-- 根据专业名称模糊查询 -->
    <select id="findByMajorName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM major
        <where>
            <if test="majorName != null and majorName != ''">
                AND major_name LIKE CONCAT('%', #{majorName}, '%')
            </if>
            AND is_deleted = 0
        </where>
        ORDER BY id ASC
    </select>

    <!-- 新增专业 -->
    <insert id="insert" parameterType="com.example.pojo.Major" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO major (major_name, major_code, remark, is_deleted)
        VALUES (#{majorName}, #{majorCode}, #{remark}, 0)
    </insert>

    <!-- 更新专业 -->
    <update id="update" parameterType="com.example.pojo.Major">
        UPDATE major
        <set>
            <if test="majorName != null">major_name = #{majorName},</if>
            <if test="majorCode != null">major_code = #{majorCode},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除专业（逻辑删除） -->
    <update id="deleteById">
        UPDATE major SET is_deleted = 1 WHERE id = #{id}
    </update>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.SysUserRoleMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.pojo.SysUserRole">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="role_id" property="roleId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, user_id, role_id, create_time
    </sql>

    <!-- 查询所有用户角色关联 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_user_role
        ORDER BY id ASC
    </select>

    <!-- 根据用户ID查询角色关联 -->
    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_user_role
        WHERE user_id = #{userId}
        ORDER BY id ASC
    </select>

    <!-- 根据角色ID查询用户关联 -->
    <select id="findByRoleId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_user_role
        WHERE role_id = #{roleId}
        ORDER BY id ASC
    </select>

    <!-- 新增用户角色关联 -->
    <insert id="insert" parameterType="com.example.pojo.SysUserRole" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user_role (user_id, role_id)
        VALUES (#{userId}, #{roleId})
    </insert>

    <!-- 批量新增用户角色关联 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO sys_user_role (user_id, role_id)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.roleId})
        </foreach>
    </insert>

    <!-- 删除用户角色关联 -->
    <delete id="deleteByUserId">
        DELETE FROM sys_user_role WHERE user_id = #{userId}
    </delete>

    <!-- 根据用户ID和角色ID删除关联 -->
    <delete id="deleteByUserIdAndRoleId">
        DELETE FROM sys_user_role WHERE user_id = #{userId} AND role_id = #{roleId}
    </delete>

</mapper>
